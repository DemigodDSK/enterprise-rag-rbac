# LLM provider — "openai" (default) or "zai"
LLM_PROVIDER=openai

# OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Z.AI fallback (only used if LLM_PROVIDER=zai)
ZAI_API_KEY=
ZAI_MODEL=glm-4-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Paths (defaults work out of the box)
DOCUMENTS_PATH=data/sample_policies
RBAC_CONFIG_PATH=config/rbac_config.json
CHROMA_DB_PATH=/tmp/chroma_db
